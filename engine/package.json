{
  "name": "@brodyazhnik/engine",
  "version": "0.1.0",
  "description": "Brodyazhnik rules engine: pure deterministic TypeScript. Zero pack content. Seedable RNG.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "main": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "journey": "tsx src/cli/journey.ts ../content-packs/kv dark-1",
    "combat": "tsx src/cli/combat.ts ../content-packs/kv ork-2",
    "council": "tsx src/cli/council.ts ../content-packs/kv council-m10"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
