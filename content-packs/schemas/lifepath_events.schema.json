{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brodyazhnik.local/schemas/lifepath_events.schema.json",
  "allOf": [
    {
      "$ref": "common.schema.json"
    }
  ],
  "properties": {
    "type": {
      "const": "lifepath_events"
    },
    "payload": {
      "type": "object",
      "required": [
        "die",
        "rows"
      ],
      "properties": {
        "die": {
          "const": "feat"
        },
        "rows": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "items": {
            "type": "object",
            "required": [
              "face",
              "became",
              "effect_text",
              "quote",
              "effects"
            ],
            "properties": {
              "face": {
                "$ref": "common.schema.json#/$defs/featDieFace"
              },
              "became": {
                "type": "string",
                "pattern": "^…"
              },
              "effect_text": {
                "type": "string",
                "minLength": 20
              },
              "quote": {
                "type": "string",
                "minLength": 10
              },
              "effects": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "common.schema.json#/$defs/effect"
                }
              },
              "engine_note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}