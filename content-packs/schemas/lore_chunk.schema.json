{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brodyazhnik.local/schemas/lore_chunk.schema.json",
  "title": "RAG lore chunk (Eriador / regions / patrons). Standalone envelope (not allOf common): adds the 'lore' id segment + 'lore_chunk' type without editing the frozen common schema.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "type",
    "title",
    "source",
    "verified",
    "locale",
    "terminology",
    "payload"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": {
      "type": "string",
      "pattern": "^kv\\.lore\\.(region|patron|npc)\\.[a-z0-9_]+$"
    },
    "type": { "const": "lore_chunk" },
    "title": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["book", "edition", "pages"],
      "properties": {
        "book": { "enum": ["igra_dlya_odnogo", "zhizn_puti_geroev", "kv_core"] },
        "edition": { "type": "string" },
        "pages": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 242 },
          "minItems": 1
        },
        "section": { "type": "string" }
      },
      "additionalProperties": false
    },
    "verified": { "type": "boolean" },
    "locale": { "const": "ru" },
    "terminology": { "const": "pandora_box" },
    "notes": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["chunk_id", "region", "kind", "text"],
      "properties": {
        "chunk_id": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["region", "patron", "npc"] },
        "text": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
