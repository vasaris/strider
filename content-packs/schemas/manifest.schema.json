{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brodyazhnik.local/schemas/manifest.schema.json",
  "title": "Content-pack manifest — engine load interface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "pack_version",
    "system",
    "sources",
    "schemas",
    "content",
    "dependencies",
    "verified"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "pack_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "locale", "terminology"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "locale": {
          "type": "string"
        },
        "terminology": {
          "type": "string"
        }
      }
    },
    "sources": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "pages"],
        "properties": {
          "title": {
            "type": "string"
          },
          "pages": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "schemas": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^\\.\\./schemas/[a-z0-9_]+\\.schema\\.json$"
      }
    },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dir", "count", "types"],
        "properties": {
          "dir": {
            "type": "string",
            "pattern": "/$"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packs"],
      "properties": {
        "packs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "verified": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "verified", "all_verified", "by_dir"],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "verified": {
          "type": "integer",
          "minimum": 0
        },
        "all_verified": {
          "type": "boolean"
        },
        "by_dir": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["total", "verified"],
            "properties": {
              "total": {
                "type": "integer",
                "minimum": 0
              },
              "verified": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  }
}
